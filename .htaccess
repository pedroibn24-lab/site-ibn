# ─── HTTPS REDIRECT ───────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── WWW → SEM WWW ────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.ibnegocios\.com\.br [NC]
RewriteRule ^ https://ibnegocios.com.br%{REQUEST_URI} [L,R=301]

# ─── REDIRECIONAMENTOS DE URLs ANTIGAS ────────────────────────
Redirect 301 /blog/ https://ibnegocios.com.br/blog.html
Redirect 301 /fale-conosco/ https://ibnegocios.com.br/#contato
Redirect 301 /termos-de-uso https://ibnegocios.com.br/privacidade-e-termos.html
Redirect 301 /educacao-corporativa/treinamentos-in-company/ https://ibnegocios.com.br/treinamentos-personalizados.html
Redirect 301 /servicos/treinamentos-in-company https://ibnegocios.com.br/treinamentos-personalizados.html
Redirect 301 /posts/ https://ibnegocios.com.br/blog.html
Redirect 301 /mudanca-no-exame-pmi/ https://ibnegocios.com.br/blog.html
Redirect 301 /quem-somos/ https://ibnegocios.com.br/#quem-somos

RewriteRule ^blog/(.+)$ https://ibnegocios.com.br/blog.html [L,R=301]
RewriteRule ^servicos/(.+)$ https://ibnegocios.com.br/#servicos [L,R=301]

# ─── SECURITY HEADERS ─────────────────────────────────────────
<IfModule mod_headers.c>

  Header always set X-Frame-Options "SAMEORIGIN"

  Header always set X-Content-Type-Options "nosniff"

  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

</IfModule>

# ─── COMPRESSÃO GZIP ──────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/json
</IfModule>

# ─── OCULTAR INFORMAÇÕES DO SERVIDOR ──────────────────────────
ServerSignature Off
